# =========================================================================
# YAP — Plantilla de configuración de variables de entorno
# =========================================================================
# Copia este archivo como .env y completa los valores antes de arrancar.
# NUNCA subas .env al repositorio — está en .gitignore.
#
# Generación de claves seguras:
#   JWT_SECRET:      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   ENCRYPTION_KEY:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =========================================================================

# ── Servidor ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development     # Cambiar a 'production' en el servidor de producción

# ── Base de datos ─────────────────────────────────────────────────────────
# Formato PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/yap_db?schema=public

# ── Autenticación ─────────────────────────────────────────────────────────
# Llave secreta para firmar los JWT de administradores (mínimo 32 caracteres aleatorios)
JWT_SECRET=REEMPLAZAR_con_clave_aleatoria_de_64_caracteres_hexadecimales

# ── Cifrado de datos PII (Ley 1581 Habeas Data) ───────────────────────────
# Llave AES-256-GCM para cifrar teléfonos, celulares y correos de Persona
# CRÍTICO: Sin esta llave los datos PII no se podrán descifrar.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REEMPLAZAR_con_clave_aleatoria_de_64_caracteres_hexadecimales

# ── URL del frontend (para CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Correo transaccional (Resend) — Opcional ─────────────────────────────
# Sin esta clave los correos se simulan en consola.
# Obtener en https://resend.com/api-keys
RESEND_API_KEY=re_REEMPLAZAR_con_tu_api_key
EMAIL_FROM=YAP Créditos <notificaciones@tudominio.com>

# ── Supabase Storage (para logos y PDFs) — Opcional ──────────────────────
# Sin estas claves el sistema usa almacenamiento local (/uploads).
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=eyJREEMPLAZAR...
SUPABASE_SERVICE_KEY=eyJREEMPLAZAR...
